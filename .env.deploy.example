# PM2 Deploy Configuration
# Скопируйте этот файл в .env.deploy и заполните реальными значениями
# Do not commit .env.deploy to repository!

# SSH user on remote server
DEPLOY_USER=root

# Remote server IP or domain
DEPLOY_HOST=example.com

# Git branch to deploy
DEPLOY_REF=origin/main

# Git repository URL
DEPLOY_REPO=git@github.com:username/repo.git

# Path to application on remote server
DEPLOY_PATH=/var/www/app

# Path to SSH key for authentication
DEPLOY_KEY=~/.ssh/id_rsa
